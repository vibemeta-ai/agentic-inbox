{
  "extends": "./tsconfig.cloudflare.json",
  "include": [
    ".react-router/types/**/*",
    "app/**/*",
    "app/**/.server/**/*",
    "app/**/.client/**/*",
    "workers/**/*",
    "shared/**/*",
    "test/**/*.ts",
    "worker-configuration.d.ts"
  ],
  "compilerOptions": {
    "types": [
      "vite/client",
      "@cloudflare/workers-types/experimental",
      "@cloudflare/vitest-pool-workers/types"
    ]
  }
}
